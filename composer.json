{
    "name": "plenta/contao-encryption",
    "description": "A replacement service for the removed Contao encryption class.",
    "type": "contao-bundle",
    "license": "MIT",
    "replace": {
        "brkwsky/contao-encryption": "self.version"
    },
    "authors": [
        {
            "name": "Plenta.io",
            "homepage": "https://plenta.io"
        }
    ],
    "funding": [{
        "type": "github",
        "url": "https://github.com/sponsors/plenta"
    }],
    "require": {
        "php": "^8.1",
        "contao/core-bundle": "^5.3",
        "phpseclib/phpseclib": "^3.0.14"
    },
    "require-dev": {
        "contao/manager-bundle": "^5.3",
        "phpunit/phpunit": "^12.5.29",
        "symfony/phpunit-bridge": "^v8.1.0",
        "phpseclib/phpseclib2_compat": "1.0.4",
        "plenta/contao-build-tools": "dev-main",
        "contao/test-case": "^5.7.0"
    },
    "conflict": {
        "contao/manager-plugin": "<2.0 || >=3.0"
    },
    "autoload": {
        "psr-4": {
            "Plenta\\ContaoEncryptionBundle\\": "src/Plenta/ContaoEncryptionBundle"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Plenta\\ContaoEncryptionBundle\\Tests\\": "tests/"
        }
    },
    "extra": {
        "contao-manager-plugin": "Plenta\\ContaoEncryptionBundle\\ContaoManager\\Plugin"
    },
    "config": {
        "allow-plugins": {
            "contao-components/installer": true,
            "contao/manager-plugin": true,
            "php-http/discovery": true,
            "plenta/contao-build-tools": true
        }
    }
}
